{
  "name": "@fulcrumapp/pg-postgis-types",
  "version": "4.0.0",
  "description": "PostGIS data types for node-postgres",
  "homepage": "https://github.com/zhm/pg-postgis-types",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "test": "jest",
    "lint": "eslint src",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "author": "Zac McCormick <zac.mccormick@gmail.com> (https://github.com/zhm)",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fulcrumapp/pg-postgis-types.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "pg": ">=8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.3.0",
    "jest": "^30.3.0",
    "pg": "^8.20.0",
    "ts-jest": "^29.4.9",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "@fulcrumapp/pg-custom-types": "^3.1.1",
    "postgres-array": "^3.0.4",
    "well-known-parser": "^0.6.1"
  },
  "keywords": [
    "sql",
    "postgres",
    "postgresql",
    "pg",
    "query",
    "database",
    "types",
    "postgis"
  ]
}
