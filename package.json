{
  "name": "@fulcrumapp/pg-postgis-types",
  "version": "4.0.0",
  "description": "PostGIS data types for node-postgres",
  "homepage": "https://github.com/zhm/pg-postgis-types",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json && node -e \"require('fs').writeFileSync('dist/esm/package.json', JSON.stringify({type:'module'}))\"",
    "build:cjs": "tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'}))\"",
    "clean": "rm -rf dist",
    "test": "jest",
    "lint": "eslint src",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "author": "Zac McCormick <zac.mccormick@gmail.com> (https://github.com/zhm)",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fulcrumapp/pg-postgis-types.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "pg": ">=8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.3.0",
    "jest": "^30.3.0",
    "pg": "^8.20.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "@fulcrumapp/pg-custom-types": "^3.1.1",
    "postgres-array": "^3.0.4",
    "well-known-parser": "^0.6.1"
  },
  "keywords": [
    "sql",
    "postgres",
    "postgresql",
    "pg",
    "query",
    "database",
    "types",
    "postgis"
  ]
}
